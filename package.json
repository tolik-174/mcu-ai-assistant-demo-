{
  "name": "0001",
  "displayName": "ai-plagin",
  "description": "ai plagin",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.102.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [ 
    "onStartupFinished",
  "onCommand:mcu-doc-assistant.openChat",
  "onCommand:mcu-doc-assistant.clearChatHistory",
  "onCommand:mcu-doc-assistant.systemInfo",
  "onCommand:mcu-doc-assistant.analyzeCode"
],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
        
        {
        "command": "mcu-doc-assistant.openChat",
        "title": "Open AI",
        "category": "MCU Assistant",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "mcu-doc-assistant.clearChatHistory",
        "title": "Clear Chat History",
        "category": "MCU Assistant",
        "icon": "$(trash)"
      },
      {
        "command": "mcu-doc-assistant.systemInfo",
        "title": "Show System Info",
        "category": "MCU Assistant",
        "icon": "$(info)"
      },
      {
        "command": "mcu-doc-assistant.analyzeCode",
        "title": "Analyze Selected Code",
        "category": "MCU Assistant",
        "icon": "$(search)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "mcu-doc-assistant.openChat",
          "when": "true"
        },
        {
          "command": "mcu-doc-assistant.clearChatHistory",
          "when": "true"
        },
        {
          "command": "mcu-doc-assistant.systemInfo",
          "when": "true"
        },
        {
          "command": "mcu-doc-assistant.analyzeCode",
          "when": "editorHasSelection"
        }
      ],
      "editor/context": [
        {
          "command": "mcu-doc-assistant.analyzeCode",
          "when": "editorHasSelection",
          "group": "1_modification"
        }
      ]
    },
    "keybindings": [
      {
        "command": "mcu-doc-assistant.openChat",
        "key": "ctrl+alt+m",
        "mac": "cmd+alt+m"
      },
      {
        "command": "mcu-doc-assistant.clearChatHistory",
        "key": "ctrl+alt+shift+c",
        "mac": "cmd+alt+shift+c"
      }
        
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.102.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "eslint": "^9.25.1",
    "esbuild": "^0.25.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.8.3",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2"
  }
}
